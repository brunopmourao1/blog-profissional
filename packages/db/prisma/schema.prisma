generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// Enums
// =============================================================

enum Role {
  SUPER_ADMIN
  AGENCY_OWNER
  AGENCY_MEMBER
  TENANT_ADMIN
  TENANT_EDITOR
}

enum PlanTier {
  STARTER
  GROWTH
  UNLIMITED
}

// =============================================================
// Agency — Agência (cliente direto da plataforma)
// =============================================================

model Agency {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  planTier          PlanTier @default(STARTER)
  stripeCustomerId  String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenants     Tenant[]
  memberships Membership[]

  @@map("agencies")
}

// =============================================================
// Tenant — Blog individual gerenciado pela agência
// =============================================================

model Tenant {
  id           String   @id @default(cuid())
  agencyId     String
  name         String
  slug         String   @unique
  customDomain String?  @unique
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agency         Agency          @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  memberships    Membership[]
  posts          Post[]
  categories     Category[]
  tags           Tag[]
  themeRevisions ThemeRevision[]

  @@index([agencyId])
  @@map("tenants")
}

// =============================================================
// User — Usuário da plataforma
// =============================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships Membership[]
  posts       Post[]

  @@map("users")
}

// =============================================================
// Membership — Associação user ↔ agency/tenant com role
// =============================================================

model Membership {
  id        String   @id @default(cuid())
  userId    String
  agencyId  String?
  tenantId  String?
  role      Role
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency Agency? @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, agencyId])
  @@unique([userId, tenantId])
  @@index([agencyId])
  @@index([tenantId])
  @@map("memberships")
}

// =============================================================
// Content Enums
// =============================================================

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

// =============================================================
// Post — Conteúdo do blog
// =============================================================

model Post {
  id             String     @id @default(cuid())
  tenantId       String
  authorId       String
  title          String
  slug           String
  content        String     @db.Text
  excerpt        String?    @db.Text
  coverImage     String?
  status         PostStatus @default(DRAFT)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  ogImage        String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id])
  categories Category[] @relation("PostCategories")
  tags       Tag[]      @relation("PostTags")

  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, publishedAt])
  @@index([authorId])
  @@map("posts")
}

// =============================================================
// Category — Categoria de posts
// =============================================================

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts  Post[] @relation("PostCategories")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

// =============================================================
// Tag — Tag de posts
// =============================================================

model Tag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  posts  Post[] @relation("PostTags")

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("tags")
}

// =============================================================
// ThemeRevision — Revisão de tema com design tokens
// =============================================================

model ThemeRevision {
  id        String   @id @default(cuid())
  tenantId  String
  version   Int      @default(1)
  active    Boolean  @default(false)
  tokens    Json
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, version])
  @@index([tenantId, active])
  @@map("theme_revisions")
}
