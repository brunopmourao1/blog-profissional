# Application
NODE_ENV="development"
PORT=4000
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Stripe (Billing)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_GROWTH=""
STRIPE_PRICE_UNLIMITED=""

# Sentry (Error Tracking)
SENTRY_DSN=""

# Vercel (Deploy)
VERCEL_URL=""
